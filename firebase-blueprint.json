{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "A patient registered in the hospital",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nik": { "type": "string" },
        "namaLengkap": { "type": "string" },
        "istri": { "type": "string" },
        "pekerjaan": { "type": "string" },
        "kotaLahir": { "type": "string" },
        "tanggalLahir": { "type": "string" },
        "jenisKelamin": { "type": "string", "enum": ["L", "P"] },
        "statusPernikahan": { "type": "string" },
        "riwayatAlergi": { "type": "string" },
        "tanggalRegistrasi": { "type": "string" },
        "jumlahKunjungan": { "type": "number" }
      },
      "required": ["id", "nik", "namaLengkap", "pekerjaan", "kotaLahir", "tanggalLahir", "jenisKelamin", "statusPernikahan", "riwayatAlergi", "tanggalRegistrasi", "jumlahKunjungan"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor in the hospital",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "spesialisasi": { "type": "string" }
      },
      "required": ["id", "nama", "spesialisasi"]
    },
    "QueueState": {
      "title": "QueueState",
      "description": "The state of the queue for a specific day",
      "type": "object",
      "properties": {
        "tanggal": { "type": "string" },
        "currentNumber": { "type": "number" },
        "nextNumber": { "type": "number" },
        "totalHariIni": { "type": "number" },
        "menunggu": { "type": "number" },
        "selesai": { "type": "number" },
        "list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "nomor": { "type": "number" },
              "patientId": { "type": "string" },
              "nama": { "type": "string" },
              "status": { "type": "string", "enum": ["Menunggu", "Sedang Diperiksa", "Selesai", "Dilewati"] },
              "waktuDaftar": { "type": "string" }
            },
            "required": ["id", "nomor", "patientId", "nama", "status", "waktuDaftar"]
          }
        }
      },
      "required": ["tanggal", "currentNumber", "nextNumber", "totalHariIni", "menunggu", "selesai", "list"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A patient's visit to the hospital",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "tanggalKunjungan": { "type": "string" },
        "dokterId": { "type": "string" },
        "operatorId": { "type": "string" },
        "anamnesa": { "type": "string" },
        "pemeriksaanFisik": { "type": "string" },
        "pemeriksaanPenunjang": { "type": "string" },
        "diagnosis": { "type": "string" },
        "terapi": { "type": "string" },
        "tindakan": { "type": "string" },
        "status": { "type": "string", "enum": ["Menunggu", "Diperiksa", "Selesai"] },
        "totalBiaya": { "type": "number" }
      },
      "required": ["id", "patientId", "tanggalKunjungan", "dokterId", "operatorId", "anamnesa", "pemeriksaanFisik", "pemeriksaanPenunjang", "diagnosis", "terapi", "tindakan", "status", "totalBiaya"]
    }
  },
  "firestore": {
    "patients": {
      "schema": "Patient",
      "description": "Collection of all patients"
    },
    "doctors": {
      "schema": "Doctor",
      "description": "Collection of all doctors"
    },
    "queues": {
      "schema": "QueueState",
      "description": "Collection of queue states per day (document ID is the date, e.g., '2026-04-01')"
    },
    "visits": {
      "schema": "Visit",
      "description": "Collection of all visits"
    }
  }
}
